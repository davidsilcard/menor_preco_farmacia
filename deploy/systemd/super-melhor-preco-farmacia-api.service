[Unit]
Description=Super Melhor Preco Farmacia API
After=network.target

[Service]
Type=simple
User=david
Group=david
WorkingDirectory=/home/david/apps/super_melhor_preco_farmacia/services/pricing-core
EnvironmentFile=/etc/super-melhor-preco-farmacia/app.env
ExecStart=/home/david/apps/super_melhor_preco_farmacia/services/pricing-core/.venv/bin/python -m src.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
